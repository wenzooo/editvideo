# === Sicurezza (obbligatorio in cloud) ===
ADMIN_PASSWORD=changeme
# SECRET_KEY=stringa-casuale-lunga   # se vuoto viene generata e salvata in data/secret.key
# APP_ENV=dev                  # "prod" rifiuta l'avvio se ADMIN_PASSWORD=changeme

# === Database ===
# vuoto = SQLite in ./data/app.db (dev). In docker-compose viene impostato Postgres.
# DATABASE_URL=postgresql+psycopg://editvideo:editvideo@db:5432/editvideo

# === Percorsi ===
# MEDIA_ROOT=./media
# DATA_DIR=./data

# === Trascrizione (faster-whisper, gratis, CPU-only) ===
WHISPER_MODEL=small          # tiny | base | small | medium
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=it          # vuoto = auto-detect
# WHISPER_BEAM=1
# WHISPER_CPU_THREADS=0      # 0 = auto

# === Sottotitoli ===
SUB_MAX_CHARS=42
# SUB_FONT=DejaVu Sans       # default: Arial su Windows, DejaVu Sans su Linux

# === Upload ===
# MAX_UPLOAD_FILES=10          # numero massimo di file per singola richiesta di upload
# MAX_REQUEST_MB=0             # tetto sull'intera richiesta (413 sul Content-Length); 0 = auto

# === Export ===
# EXPORT_CRF=20
# EXPORT_PRESET=veryfast

# === Retention / pulizia automatica (sweep nel worker) ===
# RETENTION_EXPORTS_DAYS=14    # export piu' vecchi di N giorni cancellati (0 = mai); gli originali non si toccano
# RETENTION_JOBS_DAYS=30       # job terminati oltre N giorni eliminati dalla coda (0 = mai)
# RETENTION_SWEEP_SECONDS=3600 # intervallo (s) tra due passate di pulizia

# === Worker ===
EMBEDDED_WORKER=1            # 0 quando usi il servizio worker separato (compose)
WORKER_CONCURRENCY=1

# === Resilienza job / degradazione graziosa ===
# JOB_MAX_RETRIES=2               # tentativi extra di un job fallito (0 = nessun retry)
# JOB_RETRY_BACKOFF_SECONDS=3     # attesa base (s) tra i tentativi (backoff esponenziale)
# WHISPER_FALLBACK_MODEL=small    # modello piu' leggero se il principale non carica (vuoto = nessun fallback)
# EXPORT_ALLOW_WITHOUT_SUBS=1     # se la trascrizione fallisce, esporta comunque SENZA sottotitoli

# === Observability ===
# HEALTH_DEEP=1                   # /api/health autenticato verifica anche db/disco/coda (0 = payload leggero)
# METRICS_ENABLED=1              # espone /api/metrics (contatori job/video); 0 = 404
# REQUEST_ID_HEADER=X-Request-ID  # header dell'id di correlazione (log/tracing)

# === Performance / cache ===
# MEDIA_CACHE_MAX_AGE=86400       # max-age (s) del Cache-Control sui media (export immutabili)
# PROBE_CACHE_SIZE=256            # dimensione della cache LRU dei probe ffprobe (per path)

# === Rate limit upload (per IP) ===
# UPLOAD_RATE_MAX=30              # upload consentiti per IP nella finestra
# UPLOAD_RATE_WINDOW_SECONDS=60   # ampiezza (s) della finestra scorrevole

# === Feature flags ===
# FEATURE_FLAGS=nome=1,altro=0    # interruttori runtime letti da services/flags.py (vuoto = tutti spenti)
